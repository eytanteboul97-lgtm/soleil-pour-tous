# Clé API Resend (https://resend.com) — pour l'envoi de l'email de notification
# de lead. Créer un compte gratuit, puis "API Keys" -> "Create API Key".
RESEND_API_KEY=

# Adresse email qui reçoit chaque nouvelle demande d'étude (la vôtre).
LEAD_NOTIFICATION_EMAIL=

# Optionnel : adresse d'expédition personnalisée une fois un domaine vérifié
# dans Resend (ex: "Soleil Pour Tous <contact@soleilpourtous.fr>").
# Sans domaine vérifié, laisser vide pour utiliser onboarding@resend.dev.
LEAD_FROM_EMAIL=

# Optionnel : clé API Google Places (Maps JavaScript API + Places API activées,
# restreinte par référent HTTP à ce domaine dans Google Cloud Console).
# Active l'auto-complétion d'adresse dans le formulaire. Sans clé, le champ
# adresse reste une saisie manuelle classique — aucune fonctionnalité cassée.
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=
